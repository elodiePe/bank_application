# Server
PORT=4000
NODE_ENV=development

# Frontend origin allowed to call this API (CORS)
WEB_ORIGIN=http://localhost:5173

# Database (SQLite for dev; will become a PostgreSQL URL in production)
DATABASE_URL="file:./dev.db"

# Auth secrets (set to long random values in real environments)
JWT_ACCESS_SECRET=changeme-access
JWT_REFRESH_SECRET=changeme-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Set to true once served over HTTPS in production (marks auth cookies Secure)
COOKIE_SECURE=false

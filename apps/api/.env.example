# Server (named API_PORT, not PORT, so it can never collide with an ambient
# PORT env var some tools/hosts inject for "the" web process)
API_PORT=4000
NODE_ENV=development

# Frontend origin allowed to call this API (CORS). In production this must be the exact
# GitHub Pages origin (e.g. https://username.github.io), not a wildcard.
WEB_ORIGIN=http://localhost:5173

# PostgreSQL (Supabase). DATABASE_URL is the pooled connection (port 6543, used at
# runtime); DIRECT_URL is the session connection (port 5432, used for migrations).
# Both come from Supabase → Project Settings → Database → Connect → ORMs → Prisma.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres"

# Auth secrets (set to long random values in real environments)
JWT_ACCESS_SECRET=changeme-access
JWT_REFRESH_SECRET=changeme-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Set to true once served over HTTPS in production. Also switches cookies to
# SameSite=None (required since the frontend and API are on different domains),
# which itself requires Secure — so this one flag drives both.
COOKIE_SECURE=false

# Web Push (VAPID) — generate your own with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Family owner login (creates/logs into a family) — only used in plaintext by the seed
# script (to compute the bcrypt hash stored in Family.ownerPasswordHash); never read
# at runtime.
FAMILY_OWNER_EMAIL=change-me@example.com
FAMILY_OWNER_PASSWORD=change-me-too
FAMILY_OWNER_SECRET=change-me-as-well
FAMILY_OWNER_TTL_SECONDS=2592000

# Signs the short-lived tokens embedded in transactional email links
# (verify-email, confirm-account-deletion)
EMAIL_ACTION_SECRET=change-me-email-action

# Transactional email via SMTP (e.g. Infomaniak: mail.infomaniak.com, port 587, STARTTLS).
# Leave SMTP_HOST empty in dev: emails are logged to the server console instead of being sent.
SMTP_HOST=
SMTP_PORT=587
# true only for port 465 (implicit TLS); port 587 uses STARTTLS, so leave this false.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Banque Familiale <no-reply@example.com>"

# Stock market data (Finnhub — https://finnhub.io), free tier.
FINNHUB_API_KEY=
